# Personal AI Voice Assistant - Environment Configuration
# Copy this file to .env and fill in your actual values
# IMPORTANT: Never commit .env file to version control!

# OpenWeatherMap API Configuration
# Get your free API key from: https://openweathermap.org/api
WEATHER_API_KEY=your_openweathermap_api_key_here

# Music Directory Configuration
# Set the path to your local music folder
# Windows example: D:\Music
# macOS/Linux example: /Users/username/Music
MUSIC_DIR=/path/to/your/music/directory

# Optional: Text-to-Speech Configuration
# Speech rate (50-300, default: 200)
SPEECH_RATE=200

# Speech volume (0.0-1.0, default: 0.9)
SPEECH_VOLUME=0.9

# Optional: Logging Configuration
LOG_LEVEL=INFO
# LOG_FILE=nova.log

# Optional: Additional API Keys
# STOCK_API_KEY=your_stock_api_key
# NEWS_API_KEY=your_news_api_key
# GMAIL_PASSWORD=your_gmail_password_or_app_token
